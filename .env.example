# Public Supabase project URL used by browser and server clients.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase publishable key. Do not put a service role key here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase key for future invite/admin operations.
SUPABASE_SECRET_KEY=

# Canonical local or deployed app URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

